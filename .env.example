# Cloudflare account id
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare account token
CLOUDFLARE_D1_TOKEN=

# Cloudflare D1 id
CLOUDFLARE_DATABASE_ID=

# Better Config
BETTER_AUTH_URL=http://localhost:3000

# Generate a secret key: `pnpm dlx @better-auth/cli secret`
BETTER_AUTH_SECRET= 

# Resend API Token, used for sending emails if you don't have Worker Paid Plan
RESEND_TOKEN=